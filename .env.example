# Salin file ini menjadi .env dan isi nilainya

# MySQL Database
DB_NAME=rag_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Gemini API — dapatkan GRATIS di aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# JWT Auth — generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# MIS Database (Read-Only)
# Buat user read-only di MySQL dulu:
#   CREATE USER 'mis_readonly'@'localhost' IDENTIFIED BY 'password';
#   GRANT SELECT ON mis_db.* TO 'mis_readonly'@'localhost';
#   FLUSH PRIVILEGES;
MIS_DB_ENABLED=False
MIS_DB_NAME=mis_db
MIS_DB_USER=mis_readonly
MIS_DB_PASSWORD=your_mis_readonly_password
MIS_DB_HOST=localhost
MIS_DB_PORT=3306
MIS_QUERY_TIMEOUT=10
MIS_QUERY_MAX_ROWS=500

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_CHUNKS=5
