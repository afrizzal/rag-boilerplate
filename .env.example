# Salin file ini menjadi .env dan isi nilainya

# MySQL Database
DB_NAME=rag_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Gemini API — dapatkan GRATIS di aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_CHUNKS=5
